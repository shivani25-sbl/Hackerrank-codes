#include<stdio.h>
#include<stdlib.h>
#include<math.h>
#define MAX 1000
int n;
int front=-1,rear=-1;
int queue[MAX];
int isFull(){
    return rear==n-1;
}

int isEmpty(){
    return front==-1;
}

void enqueue(int data){
    if(isFull()){
        printf("Queue Overflow\n");
        return;
    }
    
    if(front==-1)
        front=0;
    queue[++rear]=data;
}
                                       
void dequeue(){
    if(isEmpty()){
        printf("Queue Underflow\n");
        return;
    }
    int val=queue[front++];
    printf("%d\n",val);
    if(front>rear)
        front=rear=-1;                                   
}

void peek(){
    if(isEmpty()){
        printf("Queue Underflow\n");
        return;
    }
    printf("%d\n",queue[front]);
}   

void display(){
    if(isEmpty()){
        printf("Queue is Empty\n");
        return;
    }
    for(int i=front;i<=rear;i++){
        printf("%d ",queue[i]);
    }
    printf("\n");
}

int main(){
    int choice,value,num;
    scanf("%d",&n);
    
    scanf("%d",&num);
    for(int i=0;i<num;i++){
        scanf("%d",&choice);
        switch(choice){
            case 1:
                scanf("%d",&value);
                enqueue(value);
                break;
            case 2:
                dequeue();
                break;
            case 3:
                peek();
                break;
            case 4:
                display();
                break;
        }
    }
    return 0;
}
